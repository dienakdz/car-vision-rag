# LLM runtime config (Gemini)
# Get API key at: https://aistudio.google.com/apikey
LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta
LLM_API_KEY=PASTE_YOUR_GEMINI_API_KEY
LLM_MODEL=gemini-2.5-flash

# Generation controls
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700
LLM_TIMEOUT_SEC=45

# RAG context controls
LLM_CONTEXT_DOCS=5
LLM_CONTEXT_CHARS=1200
CHAT_RETRIEVAL_LIMIT=5
PDF_RETRIEVAL_LIMIT=5
